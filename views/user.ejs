<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perfil de Usuario - <%= user.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0f172a;
            background-image: radial-gradient(at 100% 0%, hsla(339,49%,30%,0.3) 0, transparent 50%), radial-gradient(at 0% 100%, hsla(253,16%,7%,1) 0, transparent 50%);
            background-attachment: fixed; color: #e2e8f0;
        }
        .glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .status-Pendiente { background: rgba(234, 179, 8, 0.2); color: #facc15; }
        .status-Completado { background: rgba(34, 197, 94, 0.2); color: #4ade80; }
        .status-Cancelado { background: rgba(239, 68, 68, 0.2); color: #f87171; }

        @media (max-width: 1024px) {
            .responsive-table thead { display: none; }
            .responsive-table tr { display: block; margin-bottom: 1rem; background: rgba(255,255,255,0.03); border-radius: 1rem; border: 1px solid rgba(255,255,255,0.08); padding: 1rem; }
            .responsive-table td { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); text-align: right; }
            .responsive-table td:last-child { border-bottom: none; }
            .responsive-table td::before { content: attr(data-label); font-weight: 600; color: #9ca3af; text-transform: uppercase; font-size: 0.75rem; text-align: left; margin-right: 1rem; }
        }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8 font-sans pb-20">
    <div class="max-w-7xl mx-auto space-y-6">
        
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between glass p-6 rounded-2xl gap-4">
            <div>
                <a href="/" class="text-blue-400 hover:text-blue-300 text-sm mb-2 inline-block font-semibold">← Volver al Dashboard</a>
                <h1 class="text-3xl font-bold text-white"><%= user.name %></h1>
                <p class="text-gray-400 text-sm mt-1">Email: <%= user.email %> | ID de Usuario: <%= user.id %></p>
            </div>
            <div class="bg-white/10 px-4 py-2 rounded-lg border border-white/10 text-center w-full md:w-auto">
                <p class="text-xs text-gray-400 uppercase">Total Transacciones</p>
                <p class="text-2xl font-bold text-white"><%= transactions.length %></p>
            </div>
        </div>

        <div>
            <h2 class="text-xl font-bold text-white mb-4 pl-2 border-l-4 border-blue-500">Métodos de Pago Registrados</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <% if(methods.length === 0) { %>
                    <p class="text-gray-500 italic">No hay métodos registrados.</p>
                <% } %>
                <% methods.forEach(m => { %>
                    <div class="glass p-4 rounded-xl hover:bg-white/10 transition">
                        <div class="flex justify-between items-center border-b border-white/10 pb-2 mb-2">
                            <span class="font-bold text-blue-300"><%= m.type %></span>
                        </div>
                        <p class="text-sm text-gray-300 space-y-1">
                            <%= m.owner_name ? `Titular: ${m.owner_name}` : '' %><br>
                            <%= m.ci ? `CI: ${m.ci}` : '' %><br>
                            <%= m.bank ? `Banco: ${m.bank}` : '' %><br>
                            <%= m.phone ? `Tlf: ${m.phone}` : '' %><br>
                            <%= m.mail_pay ? `Correo: ${m.mail_pay}` : '' %>
                        </p>
                    </div>
                <% }) %>
            </div>
        </div>

        <div>
            <h2 class="text-xl font-bold text-white mb-4 pl-2 border-l-4 border-purple-500">Historial de Transacciones</h2>
            <div class="glass rounded-2xl w-full p-2 lg:p-0">
                <table class="w-full text-left border-collapse responsive-table">
                    <thead class="bg-white/5 hidden lg:table-header-group">
                        <tr class="border-b border-white/10 text-gray-300 text-[11px] uppercase tracking-wider">
                            <th class="p-4">ID</th>
                            <th class="p-4">Tipo</th>
                            <th class="p-4">Monto USD</th>
                            <th class="p-4">Comisión USD</th>
                            <th class="p-4">Total USD</th>
                            <th class="p-4">Tasa (BS)</th>
                            <th class="p-4">Total BS</th>
                            <th class="p-4">Cuenta</th>
                            <th class="p-4">Estatus</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm">
                        <% if(transactions.length === 0) { %>
                            <tr><td colspan="9" class="p-4 text-center text-gray-500">Sin transacciones registradas</td></tr>
                        <% } %>
                        <% transactions.forEach(tx => { %>
                            <tr class="border-b border-white/5 hover:bg-white/5 transition lg:table-row">
                                <td data-label="ID" class="p-3 font-bold text-white">#<%= tx.id %></td>
                                <td data-label="Tipo" class="p-3 text-purple-300 font-semibold"><%= tx.transaction_type %></td>
                                <td data-label="Monto USD" class="p-3">$<%= tx.amount_usd %></td>
                                <td data-label="Comisión USD" class="p-3 text-red-300">-$<%= tx.commission_usd %></td>
                                <td data-label="Total USD" class="p-3 font-bold text-green-400">$<%= tx.total_usd %></td>
                                <td data-label="Tasa (BS)" class="p-3 text-gray-400"><%= tx.rate_bs %></td>
                                <td data-label="Total BS" class="p-3 font-bold text-blue-300">Bs. <%= tx.total_bs %></td>
                                
                                <td data-label="Cuenta" class="p-3 text-xs text-gray-400">
                                    <% if (tx.recipient_account) { %>
                                        <div class="flex items-center justify-end lg:justify-start gap-2">
                                            <span class="truncate max-w-[120px] lg:max-w-[150px]" title="<%= tx.recipient_account %>">
                                                <%= tx.recipient_account %>
                                            </span>
                                            <button onclick="copyToClipboard('<%= tx.recipient_account %>', this)" class="text-gray-500 hover:text-blue-400 transition focus:outline-none bg-white/5 hover:bg-white/10 p-1.5 rounded-md border border-white/5" title="Copiar cuenta">
                                                <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                                                <svg class="w-4 h-4 check-icon hidden text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                            </button>
                                        </div>
                                    <% } else { %>
                                        <span class="text-gray-500 italic">N/A</span>
                                    <% } %>
                                </td>

                                <td data-label="Estatus" class="p-3">
                                    <% if (tx.status === 'Pendiente') { %>
                                        <select onchange="updateStatus('<%= tx.id %>', this.value)" class="bg-gray-800 text-yellow-400 border border-yellow-500/50 rounded-lg px-2 py-1 text-xs focus:outline-none cursor-pointer">
                                            <option value="Pendiente" selected>Pendiente</option>
                                            <option value="Completado" class="text-green-400 bg-gray-900">Completado</option>
                                            <option value="Cancelado" class="text-red-400 bg-gray-900">Cancelado</option>
                                        </select>
                                    <% } else { %>
                                        <span class="px-2 py-1 rounded-full text-xs font-semibold status-<%= tx.status %> border">
                                            <%= tx.status %>
                                        </span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="toast" class="fixed bottom-4 right-4 glass px-4 py-3 rounded-xl shadow-lg border-l-4 border-l-green-400 text-sm text-white transform translate-y-20 opacity-0 transition-all duration-300 z-50 flex items-center gap-2 pointer-events-none">
        <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        ¡Copiado al portapapeles!
    </div>

    <script>
        async function updateStatus(transactionId, newStatus) {
            if(!confirm(`¿Actualizar transacción #${transactionId} a ${newStatus}?`)) {
                location.reload(); 
                return;
            }
            
            try {
                const response = await fetch(`/api/transaction/${transactionId}/status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: newStatus })
                });
                
                const data = await response.json();
                if (data.success) {
                    location.reload(); 
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                alert('Error de conexión con el servidor');
            }
        }

        async function copyToClipboard(text, btnElement) {
            try {
                await navigator.clipboard.writeText(text);
                
                const copyIcon = btnElement.querySelector('.copy-icon');
                const checkIcon = btnElement.querySelector('.check-icon');
                
                copyIcon.classList.add('hidden');
                checkIcon.classList.remove('hidden');
                btnElement.classList.add('border-green-500/50', 'bg-green-500/10');
                
                const toast = document.getElementById('toast');
                toast.classList.remove('translate-y-20', 'opacity-0');
                
                setTimeout(() => {
                    copyIcon.classList.remove('hidden');
                    checkIcon.classList.add('hidden');
                    btnElement.classList.remove('border-green-500/50', 'bg-green-500/10');
                    toast.classList.add('translate-y-20', 'opacity-0');
                }, 2000);

            } catch (err) {
                console.error('Error al copiar: ', err);
                alert('Tu navegador no permite copiar automáticamente.');
            }
        }
    </script>
</body>
</html>