<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Todas las Transacciones</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-color: #0f172a;
            background-image: radial-gradient(at 0% 0%, hsla(253,16%,7%,1) 0, transparent 50%), radial-gradient(at 50% 0%, hsla(225,39%,30%,0.3) 0, transparent 50%);
            background-attachment: fixed; color: #e2e8f0;
        }
        .glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .glass-row:hover { background: rgba(255, 255, 255, 0.1); cursor: pointer; transition: 0.3s; }
        .status-Pendiente { background: rgba(234, 179, 8, 0.2); color: #facc15; border: 1px solid rgba(234, 179, 8, 0.5); }
        .status-Completado { background: rgba(34, 197, 94, 0.2); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.5); }
        .status-Cancelado { background: rgba(239, 68, 68, 0.2); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.5); }

        /* Magia para convertir Tabla a Cards en Móviles */
        @media (max-width: 768px) {
            .responsive-table thead { display: none; }
            .responsive-table tr { display: block; margin-bottom: 1rem; background: rgba(255,255,255,0.05); border-radius: 1rem; border: 1px solid rgba(255,255,255,0.1); padding: 1rem; }
            .responsive-table td { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); text-align: right; }
            .responsive-table td:last-child { border-bottom: none; padding-bottom: 0; }
            .responsive-table td::before { content: attr(data-label); font-weight: 600; color: #9ca3af; text-transform: uppercase; font-size: 0.75rem; text-align: left; margin-right: 1rem; }
        }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8 font-sans">
    <div class="max-w-7xl mx-auto">
        <header class="mb-8">
            <h1 class="text-3xl font-bold text-white drop-shadow-lg">Transacciones Globales</h1>
            <p class="text-gray-400 mt-2">Haz clic en cualquier transacción para ver los detalles del usuario.</p>
        </header>

        <div class="glass rounded-2xl md:overflow-hidden w-full p-2 md:p-0">
            <table class="w-full text-left border-collapse responsive-table">
                <thead class="bg-white/5 hidden md:table-header-group">
                    <tr class="border-b border-white/10 text-gray-300 text-sm uppercase tracking-wider">
                        <th class="p-4">ID</th>
                        <th class="p-4">Referencia</th>
                        <th class="p-4">Usuario</th>
                        <th class="p-4">Tipo</th>
                        <th class="p-4">Monto</th>
                        <th class="p-4">Estado</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <% transactions.forEach(tx => { %>
                        <tr class="border-b border-white/5 glass-row md:table-row" onclick="window.location.href='/user/<%= tx.user_id %>'">
                            <td data-label="ID" class="p-2 md:p-4 font-bold text-white">#<%= tx.id %></td>
                            <td data-label="Referencia" class="p-2 md:p-4 text-gray-300"><%= tx.payment_reference || 'N/A' %></td>
                            <td data-label="Usuario" class="p-2 md:p-4">
                                <div class="font-semibold text-white"><%= tx.user_name %></div>
                                <div class="text-xs text-gray-400">ID: <%= tx.user_id %></div>
                            </td>
                            <td data-label="Tipo" class="p-2 md:p-4 text-blue-300 font-semibold"><%= tx.transaction_type %></td>
                            <td data-label="Monto" class="p-2 md:p-4 font-bold text-green-400">$<%= tx.total_usd %></td>
                            <td data-label="Estado" class="p-2 md:p-4">
                                <span class="px-3 py-1 rounded-full text-xs font-semibold status-<%= tx.status %>"><%= tx.status %></span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>