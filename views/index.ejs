<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Financiero</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Diseño Oscuro y Glassmorphism */
        body {
            background-color: #0f172a;
            background-image: 
                radial-gradient(at 0% 0%, hsla(253,16%,7%,1) 0, transparent 50%), 
                radial-gradient(at 50% 0%, hsla(225,39%,30%,0.3) 0, transparent 50%), 
                radial-gradient(at 100% 0%, hsla(339,49%,30%,0.3) 0, transparent 50%);
            background-attachment: fixed;
            color: #e2e8f0;
        }
        
        .glass {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        }

        .glass-row:hover { background: rgba(255, 255, 255, 0.1); cursor: pointer; transition: 0.3s; }
        
        /* Scrollbar personalizada */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.4); }

        /* Estilos de Status */
        .status-Pendiente { background: rgba(234, 179, 8, 0.2); color: #facc15; border: 1px solid #facc15; }
        .status-Completado { background: rgba(34, 197, 94, 0.2); color: #4ade80; border: 1px solid #4ade80; }
        .status-Cancelado { background: rgba(239, 68, 68, 0.2); color: #f87171; border: 1px solid #f87171; }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8 font-sans antialiased">

    <div class="max-w-7xl mx-auto">
        <header class="mb-8 flex justify-between items-center">
            <h1 class="text-3xl font-bold tracking-wider text-white drop-shadow-lg">Transacciones</h1>
        </header>

        <div class="glass rounded-2xl overflow-hidden w-full overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-white/10 text-gray-300 text-sm uppercase tracking-wider">
                        <th class="p-4">ID / Fecha</th>
                        <th class="p-4">Usuario</th>
                        <th class="p-4">Tipo</th>
                        <th class="p-4">Monto (USD/BS)</th>
                        <th class="p-4">Ref / Método</th>
                        <th class="p-4">Estado</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <% transactions.forEach(tx => { %>
                        <tr class="border-b border-white/5 glass-row" onclick="openUserModal('<%= tx.user_id %>')">
                            <td class="p-4">
                                <div class="font-bold text-white">#<%= tx.id %></div>
                                <div class="text-xs text-gray-400"><%= new Date(tx.created_at).toLocaleString() %></div>
                            </td>
                            <td class="p-4">
                                <div class="font-semibold text-white"><%= tx.user_name %></div>
                            </td>
                            <td class="p-4">
                                <span class="px-2 py-1 rounded text-xs <%= tx.transaction_type === 'Comprar' ? 'bg-blue-500/20 text-blue-300 border border-blue-500/30' : 'bg-purple-500/20 text-purple-300 border border-purple-500/30' %>">
                                    <%= tx.transaction_type %>
                                </span>
                            </td>
                            <td class="p-4">
                                <div class="font-bold text-green-400">$<%= tx.total_usd %></div>
                                <div class="text-xs text-gray-400">Bs. <%= tx.total_bs %></div>
                            </td>
                            <td class="p-4 text-gray-300">
                                <%= tx.payment_reference || 'N/A' %> <br>
                                <span class="text-xs text-gray-500"><%= tx.type_pay %></span>
                            </td>
                            <td class="p-4" onclick="event.stopPropagation();">
                                <% if (tx.status === 'Pendiente') { %>
                                    <select onchange="updateStatus('<%= tx.id %>', this.value)" class="bg-gray-800 text-yellow-400 border border-yellow-500/50 rounded-lg px-3 py-1 text-xs focus:outline-none focus:ring-2 focus:ring-yellow-500">
                                        <option value="Pendiente" selected>Pendiente</option>
                                        <option value="Completado" class="text-green-400">Completado</option>
                                        <option value="Cancelado" class="text-red-400">Cancelado</option>
                                    </select>
                                <% } else { %>
                                    <span class="px-3 py-1 rounded-full text-xs font-semibold status-<%= tx.status %>" id="status-badge-<%= tx.id %>">
                                        <%= tx.status %>
                                    </span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div id="userModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 opacity-0 transition-opacity duration-300">
        <div class="glass w-full max-w-4xl rounded-3xl p-6 md:p-8 max-h-[90vh] overflow-y-auto relative transform scale-95 transition-transform duration-300" id="modalContent">
            
            <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-white bg-white/10 p-2 rounded-full transition">
                ✕
            </button>

            <div id="modalBody">
                <p class="text-center text-gray-400">Cargando datos del usuario...</p>
            </div>
            
        </div>
    </div>

    <script>
        // Actualizar el estado de la transacción mediante Fetch API
        async function updateStatus(transactionId, newStatus) {
            if(!confirm(`¿Seguro que deseas marcar la transacción #${transactionId} como ${newStatus}?`)) return;
            
            try {
                const response = await fetch(`/api/transaction/${transactionId}/status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: newStatus })
                });
                
                const data = await response.json();
                if (data.success) {
                    location.reload(); // Recargamos para ver la fila actualizada, o podríamos modificar el DOM directamente
                } else {
                    alert('Error al actualizar: ' + data.message);
                }
            } catch (error) {
                alert('Error de conexión');
            }
        }

        // Manejo del Modal
        const modal = document.getElementById('userModal');
        const modalContent = document.getElementById('modalContent');
        const modalBody = document.getElementById('modalBody');

        async function openUserModal(userId) {
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modalContent.classList.remove('scale-95');
            }, 10);

            try {
                const response = await fetch(`/api/user/${userId}/details`);
                const result = await response.json();
                
                if (result.success) {
                    const { user, methods, transactions } = result.data;
                    renderModalData(user, methods, transactions);
                }
            } catch (error) {
                modalBody.innerHTML = `<p class="text-red-400">Error al cargar datos.</p>`;
            }
        }

        function closeModal() {
            modal.classList.add('opacity-0');
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                modalBody.innerHTML = '<p class="text-center text-gray-400">Cargando datos del usuario...</p>';
            }, 300);
        }

        // Renderizar los datos dentro del modal
        function renderModalData(user, methods, transactions) {
            let html = `
                <div class="mb-6">
                    <h2 class="text-2xl font-bold text-white mb-1">${user.name}</h2>
                    <p class="text-sm text-gray-400">Email: ${user.email} | Registrado: ${new Date(user.created_at).toLocaleDateString()}</p>
                </div>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div class="glass rounded-xl p-4">
                        <h3 class="text-lg font-semibold text-white mb-3 border-b border-white/10 pb-2">Métodos de Pago (${methods.length})</h3>
                        <div class="space-y-3 max-h-60 overflow-y-auto pr-2">
                            ${methods.length === 0 ? '<p class="text-gray-400 text-sm">Sin métodos registrados</p>' : ''}
                            ${methods.map(m => `
                                <div class="bg-white/5 p-3 rounded-lg border border-white/5">
                                    <div class="flex justify-between items-center mb-1">
                                        <span class="font-bold text-blue-300 text-sm">${m.type}</span>
                                        <span class="text-xs text-gray-500">${new Date(m.created_at).toLocaleDateString()}</span>
                                    </div>
                                    <p class="text-xs text-gray-300">
                                        ${m.owner_name ? `Titular: ${m.owner_name}<br>` : ''}
                                        ${m.ci ? `CI: ${m.ci} | ` : ''} ${m.bank ? `Banco: ${m.bank}` : ''}
                                        ${m.phone ? `<br>Tlf: ${m.phone}` : ''}
                                        ${m.mail_pay ? `<br>Email Pago: ${m.mail_pay}` : ''}
                                    </p>
                                </div>
                            `).join('')}
                        </div>
                    </div>

                    <div class="glass rounded-xl p-4">
                        <h3 class="text-lg font-semibold text-white mb-3 border-b border-white/10 pb-2">Historial de Transacciones (${transactions.length})</h3>
                        <div class="space-y-3 max-h-60 overflow-y-auto pr-2">
                            ${transactions.length === 0 ? '<p class="text-gray-400 text-sm">Sin transacciones</p>' : ''}
                            ${transactions.map(t => `
                                <div class="bg-white/5 p-3 rounded-lg border border-white/5 flex justify-between items-center">
                                    <div>
                                        <div class="text-sm font-semibold text-white">#${t.id} - ${t.transaction_type}</div>
                                        <div class="text-xs text-gray-400">$${t.total_usd} | ${t.type_pay}</div>
                                    </div>
                                    <span class="px-2 py-1 rounded text-[10px] uppercase font-bold status-${t.status}">
                                        ${t.status}
                                    </span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </div>
            `;
            modalBody.innerHTML = html;
        }

        // Cerrar modal al hacer clic fuera del contenido
        modal.addEventListener('click', (e) => {
            if(e.target === modal) closeModal();
        });
    </script>
</body>
</html>